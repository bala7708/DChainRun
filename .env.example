# ChainRun environment template
# Copy this file to `.env` and replace placeholders.

# Deployer key for Hedera EVM testnet
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Oracle signer wallet
AI_AGENT_SIGNER=0xYOUR_ORACLE_PUBLIC_ADDRESS
AGENT_PRIVATE_KEY=0xYOUR_ORACLE_PRIVATE_KEY

# Hedera testnet RPC
HEDERA_RPC=https://testnet.hashio.io/api

# Contracts (auto-updated by deploy script)
GAME_ADDRESS=0xYOUR_DAVE_CHAIN_GAME_ADDRESS
ORACLE_ADDRESS=0xYOUR_DAVE_AI_ORACLE_ADDRESS
EXP_TOKEN_ADDRESS=0xYOUR_EXP_TOKEN_ADDRESS

# Oracle API port
PORT=3001
